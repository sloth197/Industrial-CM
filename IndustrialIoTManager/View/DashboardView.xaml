<UserControl x:Class="IndustrialIoTManager.View.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="520"
             d:DesignWidth="900">
    <Grid>
        <StackPanel>
            <TextBlock FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="#1E293B"
                       Text="{Binding Title}" />
            <TextBlock Margin="0,6,0,18"
                       Foreground="#64748B"
                       Text="실시간 운영 요약(초기 더미 데이터)" />

            <ItemsControl ItemsSource="{Binding SummaryItems}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,10"
                                Padding="16,12"
                                Background="#F8FAFC"
                                BorderBrush="#DCE5F0"
                                BorderThickness="1"
                                CornerRadius="10">
                            <TextBlock FontSize="15"
                                       Foreground="#0F172A"
                                       Text="{Binding}" />
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Grid>
</UserControl>
