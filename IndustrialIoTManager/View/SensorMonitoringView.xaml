<UserControl x:Class="IndustrialIoTManager.View.SensorMonitoringView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="520"
             d:DesignWidth="900">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="#1E293B"
                       Text="{Binding Title}" />
            <TextBlock Margin="0,6,0,14"
                       Foreground="#64748B"
                       Text="현장 센서의 실시간 측정값" />
        </StackPanel>

        <DataGrid Grid.Row="1"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  ItemsSource="{Binding SensorReadings}"
                  VerticalAlignment="Top"
                  MaxHeight="520"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
                <DataGridTextColumn Header="장비명" Binding="{Binding EquipmentName}" Width="2*" />
                <DataGridTextColumn Header="센서 타입" Binding="{Binding SensorType}" Width="2*" />
                <DataGridTextColumn Header="값" Binding="{Binding Value}" Width="*" />
                <DataGridTextColumn Header="단위" Binding="{Binding Unit}" Width="*" />
                <DataGridTextColumn Header="수집 시각" Binding="{Binding Timestamp}" Width="2*" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
