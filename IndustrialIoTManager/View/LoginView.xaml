<UserControl x:Class="IndustrialIoTManager.View.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="520"
             d:DesignWidth="900">
    <Grid Background="#FFFFFF">
        <Border MaxWidth="430"
                Padding="28"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#F8FAFC"
                BorderBrush="#D8E1EC"
                BorderThickness="1"
                CornerRadius="12">
            <StackPanel>
                <TextBlock Text="로그인"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Foreground="#1E293B" />
                <TextBlock Margin="0,6,0,20"
                           Foreground="#64748B"
                           Text="산업용 IoT 통합제어관리 시스템 접속" />

                <TextBlock Margin="0,0,0,6"
                           FontWeight="SemiBold"
                           Text="사용자 ID" />
                <TextBox Margin="0,0,0,14"
                         Padding="10"
                         Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Margin="0,0,0,6"
                           FontWeight="SemiBold"
                           Text="비밀번호" />
                <TextBox Margin="0,0,0,18"
                         Padding="10"
                         Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" />

                <Button Height="42"
                        Content="로그인"
                        Command="{Binding LoginCommand}"
                        Background="#0E7490"
                        Foreground="White"
                        BorderBrush="#0E7490"
                        Cursor="Hand" />

                <TextBlock Margin="0,14,0,0"
                           Foreground="#0F766E"
                           Text="{Binding StatusMessage}"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
