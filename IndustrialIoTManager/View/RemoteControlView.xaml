<UserControl x:Class="IndustrialIoTManager.View.RemoteControlView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="520"
             d:DesignWidth="900">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="#1E293B"
                       Text="{Binding Title}" />
            <TextBlock Margin="0,6,0,14"
                       Foreground="#64748B"
                       Text="원격 제어 명령 전송(초기 더미 동작)" />
        </StackPanel>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
            <ComboBox Width="220"
                      Height="34"
                      ItemsSource="{Binding EquipmentNames}"
                      SelectedItem="{Binding SelectedEquipment, UpdateSourceTrigger=PropertyChanged}" />

            <Button Margin="10,0,0,0"
                    Padding="14,6"
                    Content="START"
                    Command="{Binding StartCommand}"
                    Background="#0E7490"
                    Foreground="White"
                    BorderBrush="#0E7490" />
            <Button Margin="10,0,0,0"
                    Padding="14,6"
                    Content="STOP"
                    Command="{Binding StopCommand}"
                    Background="#B45309"
                    Foreground="White"
                    BorderBrush="#B45309" />
            <Button Margin="10,0,0,0"
                    Padding="14,6"
                    Content="RESET"
                    Command="{Binding ResetCommand}"
                    Background="#7C3AED"
                    Foreground="White"
                    BorderBrush="#7C3AED" />
        </StackPanel>

        <Border Grid.Row="2"
                Margin="0,16,0,0"
                Padding="16"
                BorderBrush="#D8E1EC"
                BorderThickness="1"
                CornerRadius="10"
                Background="#F8FAFC">
            <TextBlock Text="{Binding CommandResult}"
                       FontSize="14"
                       Foreground="#0F172A"
                       TextWrapping="Wrap" />
        </Border>
    </Grid>
</UserControl>
