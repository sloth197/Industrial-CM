<UserControl x:Class="IndustrialIoTManager.View.RemoteControlView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="520"
             d:DesignWidth="900">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="#1E293B"
                       Text="{Binding Title}" />
            <TextBlock Margin="0,6,0,14"
                       Foreground="#64748B"
                       Text="{Binding Subtitle}" />
            <TextBlock Margin="0,-6,0,0"
                       Foreground="#B91C1C"
                       FontWeight="SemiBold"
                       Text="{Binding DemoScenario}" />
        </StackPanel>

        <Border Grid.Row="1"
                Padding="14"
                Background="#F8FAFC"
                BorderBrush="#D8E1EC"
                BorderThickness="1"
                CornerRadius="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontWeight="SemiBold"
                               Foreground="#334155"
                               Text="제어 대상 장비" />
                    <ComboBox Width="260"
                              Height="34"
                              Margin="0,8,0,0"
                              IsEnabled="{Binding CanSelectEquipment}"
                              ItemsSource="{Binding EquipmentNames}"
                              SelectedItem="{Binding SelectedEquipment, UpdateSourceTrigger=PropertyChanged}" />

                    <StackPanel Orientation="Horizontal"
                                Margin="0,12,0,0">
                        <Button Padding="16,7"
                                Content="START"
                                Command="{Binding StartCommand}"
                                Background="#0E7490"
                                Foreground="White"
                                BorderBrush="#0E7490" />
                        <Button Margin="10,0,0,0"
                                Padding="16,7"
                                Content="STOP"
                                Command="{Binding StopCommand}"
                                Background="#B45309"
                                Foreground="White"
                                BorderBrush="#B45309" />
                        <Button Margin="10,0,0,0"
                                Padding="16,7"
                                Content="RESET"
                                Command="{Binding ResetCommand}"
                                Background="#0369A1"
                                Foreground="White"
                                BorderBrush="#0369A1" />
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="1"
                        Margin="14,0,0,0"
                        Padding="12"
                        Background="#FFFFFF"
                        BorderBrush="#D8E1EC"
                        BorderThickness="1"
                        CornerRadius="8">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold"
                                   Foreground="#1E293B"
                                   Text="현재 장비 상태" />
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="{Binding SelectedStatusColor}"
                                   FontWeight="SemiBold"
                                   FontSize="18"
                                   Text="{Binding SelectedStatus}" />
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="#475569"
                                   Text="{Binding SelectedLine, StringFormat=라인: {0}}" />
                        <TextBlock Margin="0,2,0,0"
                                   Foreground="#475569"
                                   Text="{Binding SelectedHeartbeat, StringFormat=최근 Heartbeat: {0}}" />
                        <TextBlock Margin="0,2,0,0"
                                   Foreground="#475569"
                                   Text="{Binding SelectedLatencyMs, StringFormat=PLC 지연시간: {0}ms}" />

                        <Border Margin="0,10,0,0"
                                Padding="8"
                                Background="#FEF2F2"
                                BorderBrush="#FECACA"
                                BorderThickness="1"
                                CornerRadius="6"
                                Visibility="{Binding HasActiveFault, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Foreground="#B91C1C"
                                       FontWeight="SemiBold"
                                       Text="{Binding ActiveFaultMessage, StringFormat=활성 Fault: {0}}" />
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Margin="0,14,0,0"
                Padding="14"
                Background="#FFFFFF"
                BorderBrush="#D8E1EC"
                BorderThickness="1"
                CornerRadius="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock FontWeight="SemiBold"
                               Foreground="#1E293B"
                               Text="명령 실행 상태" />
                    <ProgressBar Margin="0,8,0,0"
                                 Height="10"
                                 Maximum="100"
                                 Value="{Binding CommandProgress, Mode=OneWay}" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="#475569"
                               Text="{Binding CommandProgressText}" />
                    <TextBlock Margin="0,6,0,0"
                               FontWeight="SemiBold"
                               Foreground="#0F172A"
                               Text="{Binding CommandResult}" />
                </StackPanel>

                <Border Grid.Column="1"
                        Margin="12,0,0,0"
                        Padding="10"
                        Background="#F8FAFC"
                        BorderBrush="#D8E1EC"
                        BorderThickness="1"
                        CornerRadius="8">
                    <StackPanel>
                        <TextBlock Foreground="#64748B"
                                   Text="RPM" />
                        <TextBlock Margin="0,4,0,0"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="#0F172A"
                                   Text="{Binding SelectedRpm}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Margin="12,0,0,0"
                        Padding="10"
                        Background="#F8FAFC"
                        BorderBrush="#D8E1EC"
                        BorderThickness="1"
                        CornerRadius="8">
                    <StackPanel>
                        <TextBlock Foreground="#64748B"
                                   Text="온도" />
                        <TextBlock Margin="0,4,0,0"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="#0F172A"
                                   Text="{Binding SelectedTemperature}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Margin="0,14,0,0"
                Padding="16"
                BorderBrush="#D8E1EC"
                BorderThickness="1"
                CornerRadius="10"
                Background="#F8FAFC">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="#1E293B"
                           Text="제어 이벤트 로그" />
                <ListBox Grid.Row="1"
                         Margin="0,10,0,0"
                         BorderThickness="0"
                         Background="Transparent"
                         ItemsSource="{Binding CommandLogs}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
