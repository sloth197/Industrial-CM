<UserControl x:Class="IndustrialIoTManager.View.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="520"
             d:DesignWidth="900">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="#1E293B"
                       Text="{Binding Title}" />
            <TextBlock Margin="0,6,0,14"
                       Foreground="#64748B"
                       Text="IP, 포트, PLC/장비 연결 정보 설정" />
        </StackPanel>

        <Border Grid.Row="1"
                Padding="20"
                Background="#F8FAFC"
                BorderBrush="#D8E1EC"
                BorderThickness="1"
                CornerRadius="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,10,10" VerticalAlignment="Center" Text="PLC IP" />
                <TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,10" Padding="8" Text="{Binding PlcIp, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,10,10" VerticalAlignment="Center" Text="PLC Port" />
                <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,10" Padding="8" Text="{Binding PlcPort, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,10,10" VerticalAlignment="Center" Text="Gateway IP" />
                <TextBox Grid.Row="2" Grid.Column="1" Margin="0,0,0,10" Padding="8" Text="{Binding DeviceGatewayIp, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,10,10" VerticalAlignment="Center" Text="Gateway Port" />
                <TextBox Grid.Row="3" Grid.Column="1" Margin="0,0,0,10" Padding="8" Text="{Binding DeviceGatewayPort, UpdateSourceTrigger=PropertyChanged}" />

                <Button Grid.Row="4"
                        Grid.Column="1"
                        Width="140"
                        Height="36"
                        HorizontalAlignment="Left"
                        Margin="0,4,0,10"
                        Content="설정 저장"
                        Command="{Binding SaveSettingsCommand}"
                        Background="#0E7490"
                        Foreground="White"
                        BorderBrush="#0E7490" />

                <TextBlock Grid.Row="5"
                           Grid.Column="1"
                           Foreground="#0F766E"
                           Text="{Binding StatusMessage}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
