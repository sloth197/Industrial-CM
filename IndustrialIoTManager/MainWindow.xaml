<Window x:Class="IndustrialIoTManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="IndustrialIoTManager"
        Width="1366"
        Height="840"
        MinWidth="1200"
        MinHeight="700"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Foreground" Value="#F9FAFB" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="BorderBrush" Value="#2B4C73" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#1E3A5F" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#274C77" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#163150" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="270" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#102238" Padding="20">
            <DockPanel>
                <Button DockPanel.Dock="Bottom"
                        Margin="0,12,0,0"
                        Padding="14,10"
                        Content="로그아웃"
                        Command="{Binding LogoutCommand}"
                        Background="#8B1E3F"
                        Foreground="#FFFFFF"
                        BorderBrush="#B13E62"
                        BorderThickness="1"
                        Cursor="Hand" />

                <StackPanel>
                    <TextBlock Text="Industrial IoT Manager"
                               Foreground="#F8FAFC"
                               FontSize="22"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                    <TextBlock Text="통합 제어 관리 콘솔"
                               Margin="0,6,0,20"
                               Foreground="#A8BED7"
                               FontSize="12" />

                    <Button Style="{StaticResource NavButtonStyle}"
                            Content="1) 로그인"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Login" />
                    <Button Style="{StaticResource NavButtonStyle}"
                            Content="2) 메인 대시보드"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Dashboard" />
                    <Button Style="{StaticResource NavButtonStyle}"
                            Content="3) 설비/장비 목록"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="EquipmentList" />
                    <Button Style="{StaticResource NavButtonStyle}"
                            Content="4) 센서 모니터링"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="SensorMonitoring" />
                    <Button Style="{StaticResource NavButtonStyle}"
                            Content="5) 장비 원격 제어"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="RemoteControl" />
                    <Button Style="{StaticResource NavButtonStyle}"
                            Content="6) 알람/이벤트 로그"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="AlarmEventLog" />
                    <Button Style="{StaticResource NavButtonStyle}"
                            Content="7) 사용자/권한 관리"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="UserRoleManagement" />
                    <Button Style="{StaticResource NavButtonStyle}"
                            Content="8) 설정"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Settings" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Column="1" Background="#F4F7FB" Padding="18">
            <Border Background="#FFFFFF"
                    CornerRadius="12"
                    BorderBrush="#D8E1EC"
                    BorderThickness="1"
                    Padding="18">
                <ContentControl Content="{Binding CurrentPage}" />
            </Border>
        </Border>
    </Grid>
</Window>
